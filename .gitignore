# ===== Secret & Credential Protection =====
# Never commit credentials, tokens, keys, or secrets
credentials.json
**/credentials.json
**/credential*
*.secret
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore
*.truststore
*.ppk
.id_rsa
.id_ed25519
**/secrets/
**/.secrets/
**/secret_*
**/token_*

# ===== Environment & Config Files =====
.env
.env.*
!.env.example
!.env.template
!.env.sample
.env.local
.env.production
.env.staging
.env.development.local
.env.test.local

# ===== OAuth & Auth =====
oauth_tokens.json
**/oauth/
**/.oauth

# ===== Cloud Provider Credentials =====
.aws/
.azure/
.gcloud/
.config/gcloud/
**/service-account*.json
**/sa-key*.json

